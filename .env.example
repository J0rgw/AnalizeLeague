# ── Riot API ──────────────────────────────────────────────────────────────────
# Obtain a development key from https://developer.riotgames.com/
# Development keys expire every 24 hours and must be manually renewed.
# For production use, set GRID_API_KEY instead.
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Ollama ────────────────────────────────────────────────────────────────────
# Local Ollama server. Default: http://localhost:11434
# Pull a model first: ollama pull llama3.1
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to the DuckDB database file (relative to where uv run is called, i.e. /backend)
DUCKDB_PATH=../data/analizeleague.duckdb

# ── Application ───────────────────────────────────────────────────────────────
# Runtime environment: dev | prod
ENV=dev

# ── GRID (production only) ────────────────────────────────────────────────────
# Leave blank in dev/demo mode. Requires a GRID Esports partnership agreement.
# See /.ai/data-sources.md for details on GRID access modes.
GRID_API_KEY=
